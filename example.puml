[workshop] -> [spec]
[spec] -> [api]
[spec] -> [middle]
[api] -> [fe]
[api] -> [mig]
[middle] -> [sec]
[fe] -> [qa]
[middle] -> [qa]
[mig] -> [qa]
[qa] -> [bugs]
[bugs] -> [Production deploy]

